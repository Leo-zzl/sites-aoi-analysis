{
  "name": "sites_in_aoi",
  "version": "1.0.0",
  "description": "本工具用于无线通信网络规划中的**站点-AOI空间关联分析**，包含两大核心功能：",
  "main": "electron/main.js",
  "scripts": {
    "start": "electron .",
    "build:win": "electron-builder --win --x64",
    "build:mac": "electron-builder --mac",
    "test": "vitest run",
    "test:e2e": "playwright test"
  },
  "build": {
    "appId": "com.leozzl.site-analysis",
    "productName": "小区-AOI空间匹配分析",
    "copyright": "Copyright © 2026",
    "directories": {
      "output": "dist"
    },
    "files": [
      "electron/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "dist-backend/site-analysis-api",
        "to": "site-analysis-api",
        "filter": [
          "**/*"
        ]
      }
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "electron/assets/icon.ico"
    },
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": [
            "arm64",
            "x64"
          ]
        }
      ],
      "icon": "electron/assets/icon.icns",
      "signIgnore": [
        "site-analysis-api/_internal/Python.framework"
      ]
    }
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Leo-zzl/sites-aoi-analysis.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "bugs": {
    "url": "https://github.com/Leo-zzl/sites-aoi-analysis/issues"
  },
  "homepage": "https://github.com/Leo-zzl/sites-aoi-analysis#readme",
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "electron": "^41.2.1",
    "electron-builder": "^26.8.1",
    "happy-dom": "^20.9.0",
    "vitest": "^4.1.4"
  },
  "dependencies": {
    "form-data": "^4.0.5"
  }
}
